{
  "kind": "collectionType",
  "collectionName": "video_entries",
  "info": {
    "singularName": "video-entry",
    "pluralName": "video-entries",
    "displayName": "Video",
    "description": "Videos migrated from WP CPT \"videos\""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "wp_id": {
      "type": "integer",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "videoLink": {
      "type": "string"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "videoCategories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category"
    },
    "primaryVideoCategory": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
