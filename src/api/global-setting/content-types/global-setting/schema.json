      "type": "string"
    },
    "getInTouchLocation": {
      "type": "text"
    },
    "socialFacebook": {
      "type": "string"
    },
    "socialInstagram": {
      "type": "string"
    },
    "socialLinkedin": {
      "type": "string"
    },
    "socialX": {
      "type": "string"
    },
    "socialYoutube": {
      "type": "string"
    },
    "textBelowHeader": {
      "type": "string"
