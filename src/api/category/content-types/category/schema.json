{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Flat taxonomy terms migrated from WP (loan/credit-card/card-type/card-provider/company/videos categories)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "wp_id": {
      "type": "integer",
      "required": true,
      "unique": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "string"
    },
    "taxonomy": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "loan_category",
        "credit_card_category",
        "card_type",
        "card_provider",
        "company_category",
        "videos_category"
      ]
    },
    "description": {
      "type": "text"
    },
    "contentAfterTable": {
      "type": "richtext"
    },
    "faqContent": {
      "type": "component",
      "repeatable": true,
      "component": "lender.faq-item"
    }
  }
}
